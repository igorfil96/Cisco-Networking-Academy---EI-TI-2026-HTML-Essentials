<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sunnydale School | Welcome</title>
    <style>
        /* Step 1: Enhance the Page Title */
        h1 {
            font-size: 24px;
            font-weight: bold;
            color: #1E90FF;
        }

        /* Step 2: Customize Fonts and Section Colors */
        body {
            font-family: 'Arial', sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Targeting H2s specifically as requested */
        .mission-head { color: #32CD32; }
        .events-head { color: #FFA07A; }
        .contact-head { color: #20B2AA; }

        /* Step 5: Style Specific Sections with IDs and Classes */
        #upcoming-events {
            background-color: #FFFFE0;
            padding: 10px;
        }

        .outdoor {
            background-color: #AFEEEE; /* Fixed typo from ##AFEEEE */
            padding: 5px;             /* Fixed typo from 5x */
            border: 1px solid #B0E0E6;
            list-style-position: inside;
            margin-bottom: 5px;
        }

        /* Step 7: Style for the Contact Box */
        .section {
            background-color: #f8f3f3;
            padding: 10px;
            border-radius: 5px;
        }
    </style>
</head>
<body>

    <header>
        <h1>Sunnydale School</h1>
    </header>

    <section>
        <h2 class="mission-head">Mission Statement</h2>
        <p>At Sunnydale, we strive to empower students to reach their full potential through a supportive and innovative learning environment.</p>
    </section>

    <section>
        <h2 id="upcoming-events" class="events-head">Upcoming Events</h2>
        <ul>
            <li data-event-type="indoor" title="Event Type: Indoor">
                Science Fair - <span style="font-weight: bold; color: red;">June 10</span>
            </li>
            <li class="outdoor" data-event-type="outdoor" title="Event Type: Outdoor">
                Art Exhibition - <span style="font-weight: bold; color: red;">June 15</span>
            </li>
            <li class="outdoor" data-event-type="outdoor" title="Event Type: Outdoor">
                Sports Day - <span style="font-weight: bold; color: red;">June 20</span>
            </li>
        </ul>
    </section>

    <div class="section">
        <h2 class="contact-head">Contact Us</h2>
        <p>Email: <a href="mailto:info@sunnydale.edu" title="Click to copy email">info@sunnydale.edu</a></p>
        <p>Phone: <span title="Click to copy phone">(555) 123-4567</span></p>
        </div>

</body>
</html>